# Build output
/build/
/build-mingw/
/cmake-build-*/
# Per-OS and ad-hoc out-of-source build trees (root and standalone/); match at any
# depth. Covers build-win/, build-ubuntu/, and scratch trees like build-parity/,
# build-prof/, build-soa/.
build-*/

# R package build artefacts
r-package/rsymbolic2/src/*.o
r-package/rsymbolic2/src/*.so
r-package/rsymbolic2/src/*.dll
r-package/rsymbolic2/src/rsymbolic2.def
r-package/rsymbolic2/src-x64/
r-package/rsymbolic2/src-i386/
r-package/rsymbolic2/*.tar.gz
r-package/rsymbolic2/rsymbolic2.Rcheck/

# Editor / IDE
.vscode/
.idea/
*.user

# Benchmark results (generated; commit only curated summaries)
benchmarks/results/*.csv
benchmarks/results/*.log
benchmarks/results/*.log.err

# Exported benchmark input data (regenerated by benchmarks/export_nguyen_data.R)
benchmarks/data/

# SymbolicRegression.jl auto-saved per-run output
outputs/

# Python package build artefacts (the Python package compiles the shared C++ core)
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
python/build/
python/dist/
python/_skbuild/
*.so
*.pyd
.venv/

# OS
.DS_Store
Thumbs.db
